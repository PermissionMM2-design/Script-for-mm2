local menuBtn = Instance.new("ImageButton", gui)
menuBtn.Size = UDim2.new(0, 72, 0, 72)
menuBtn.Position = UDim2.new(1, -90, 0.5, -36)
menuBtn.Image = "rbxassetid://6159452397"
menuBtn.BackgroundTransparency = 1
Instance.new("UICorner", menuBtn).CornerRadius = UDim.new(1,0)

local isOpen = false

local function openGUI()
    isOpen = true
    menuBtn.Visible = false
    main.Visible = true
    overlay.Visible = true

    main.Size = UDim2.new(0, 80, 0, 80)
    main.Position = UDim2.new(0, menuBtn.AbsolutePosition.X + 36, 0, menuBtn.AbsolutePosition.Y + 36)

    TweenService:Create(overlay, TweenInfo.new(0.4), {BackgroundTransparency = 0.4}):Play()

    TweenService:Create(main, TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 560, 0, 460),
        Position = UDim2.new(0.5, -280, 0.5, -230)
    }):Play()
end

local function closeGUI()
    isOpen = false
    TweenService:Create(overlay, TweenInfo.new(0.35), {BackgroundTransparency = 1}):Play()
    TweenService:Create(main, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 80, 0, 80),
        Position = UDim2.new(0, menuBtn.AbsolutePosition.X + 36, 0, menuBtn.AbsolutePosition.Y + 36)
    }):Play()

    task.delay(0.5, function()
        main.Visible = false
        overlay.Visible = false
        menuBtn.Visible = true
    end)
end

menuBtn.MouseButton1Click:Connect(function()
    if isOpen then closeGUI() else openGUI() end
end)

overlay.InputBegan:Connect(function(i)
    if (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) and isOpen then
        closeGUI()
    end
end)

