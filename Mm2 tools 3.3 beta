local function becomeMurderer()
    local knife = ReplicatedStorage:FindFirstChild("Knife") or game:GetService("Lighting"):FindFirstChild("Knife")
    if knife then
        local clone = knife:Clone()
        clone.Parent = LocalPlayer.Character
    end
end

local function becomeSheriff()
    local gun = ReplicatedStorage:FindFirstChild("Gun") or game:GetService("Lighting"):FindFirstChild("Gun")
    if gun then
        local clone = gun:Clone()
        clone.Parent = LocalPlayer.Character
    end
end

