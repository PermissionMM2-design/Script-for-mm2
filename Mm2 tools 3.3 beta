local function createBtn(text, parent, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1,0,0,52)
    btn.BackgroundColor3 = Color3.fromRGB(255,255,255)
    btn.BackgroundTransparency = 0.2
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,12)
    Instance.new("UIStroke", btn).Thickness = 2
    Instance.new("UIStroke", btn).Color = Color3.fromRGB(255,255,255)
    Instance.new("UIStroke", btn).Transparency = 0.5

    local origSize = btn.Size
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {Size = UDim2.new(1,0,0,67)}):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = origSize}):Play()
        if callback then callback(btn) end
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = origSize}):Play()
    end)
    return btn
end

local function toggleButton(btn, state, onText, offText)
    if state then
        btn.Text = onText
        btn.TextColor3 = Color3.fromRGB(0, 255, 100)
    else
        btn.Text = offText
        btn.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end

