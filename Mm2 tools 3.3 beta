local function scanItems()
    for _, obj in ipairs(itemEspObjects) do
        pcall(function() obj:Destroy() end)
    end
    itemEspObjects = {}
    if not espItems then return end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") and obj.Parent ~= LocalPlayer.Character then
            if obj.Parent and obj.Parent:IsA("Model") and obj.Parent:FindFirstChild("Humanoid") then
                -- пропускаем, если в руках
            else
                createItemESP(obj)
            end
        end
    end
end

-- ==================== НОКЛИП ====================
local function setNoclip(state)
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = not state
        end
    end
end

-- ==================== СКОРОСТЬ / ПРЫЖОК ====================
local function updateSpeed()
    Humanoid.WalkSpeed = speedEnabled and speedValue or 16
end

local function updateJump()
    Humanoid.JumpPower = jumpEnabled and jumpValue or 50
end

-- ==================== AIMBOT ====================
local function findMurderer()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local role = getPlayerRole(player)
            if role == "Murderer" then
                local char = player.Character
                if char and char:FindFirstChild("Head") then
                    return char.Head
                end
            end
        end
    end
    return nil
end

local function aimbotUpdate()
    if not aimbotEnabled then return end
    local target = findMurderer()
    if not target then return end
    local cam = Workspace.CurrentCamera
    local targetPos = target.Position
    local currentPos = cam.CFrame.Position
    local newCFrame = CFrame.lookAt(currentPos, targetPos)
    cam.CFrame = cam.CFrame:Lerp(newCFrame, 0.2)
end

-- ==================== ТЕЛЕПОРТЫ ====================
local function teleportTo(part)
    if not part or not part:IsA("BasePart") then return end
    if RootPart then
        RootPart.CFrame = part.CFrame + Vector3.new(0, 2, 0)
    end
end

local function teleportToPlayer(player)
    if not player then return end
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        teleportTo(char.HumanoidRootPart)
    end
end

local function teleportToMurderer()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and getPlayerRole(player) == "Murderer" then
            teleportToPlayer(player)
            return
        end
    end
end

local function teleportToSheriff()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and getPlayerRole(player) == "Sheriff" then
            teleportToPlayer(player)
            return
        end
    end
end

local function teleportToWeapon()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") and obj.Parent ~= LocalPlayer.Character then
            local part = obj:FindFirstChild("Handle") or obj:FindFirstChildOfClass("BasePart")
            if part then
                teleportTo(part)
                return
            end
        end
    end
end

local function pickUpGun()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") and (obj.Name == "Gun" or obj.Name == "SheriffGun" or obj.Name == "Pistol") then
            if obj.Parent ~= LocalPlayer.Character then
                local part = obj:FindFirstChild("Handle") or obj:FindFirstChildOfClass("BasePart")
                if part then
                    teleportTo(part)
                    task.wait(0.2)
                    local click = obj:FindFirstChildOfClass("ClickDetector")
                    if click then fireclickdetector(click) end
                end
                return
            end
        end
    end
end

local function toggleShootWall(state)
