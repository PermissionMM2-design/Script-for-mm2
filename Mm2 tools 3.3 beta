-- ==================== ОПРЕДЕЛЕНИЕ РОЛЕЙ ====================
local function getPlayerRole(player)
    local char = player.Character
    if not char then return "Unknown" end
    if char:FindFirstChild("Knife") or char:FindFirstChild("MurdererKnife") then
        return "Murderer"
    end
    if char:FindFirstChild("Gun") or char:FindFirstChild("SheriffGun") then
        return "Sheriff"
    end
    if player:FindFirstChild("Role") then
        local role = player.Role.Value
        if role == "Murderer" then return "Murderer"
        elseif role == "Sheriff" then return "Sheriff"
        else return "Civilian" end
    end
    return "Civilian"
end

local function getRoleColor(player)
    local role = getPlayerRole(player)
    if role == "Murderer" then return Color3.fromRGB(255, 50, 50)
    elseif role == "Sheriff" then return Color3.fromRGB(50, 100, 255)
    elseif role == "Civilian" then return Color3.fromRGB(50, 255, 50)
    else return Color3.fromRGB(255, 215, 0) end
end

-- ==================== ESP (подсветка игроков) ====================
local function createPlayerESP(player)
    if player == LocalPlayer then return end
    if playerHighlights[player] then return end

    local char = player.Character
    if not char then return end

    local data = {
        highlights = {},
        billboard = nil,
        connections = {}
    }

    -- Highlight на каждую часть тела
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            local hl = Instance.new("Highlight")
            hl.Parent = part
            hl.Adornee = part
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.FillTransparency = 0.5
            hl.OutlineTransparency = 0.3
            local color = getRoleColor(player)
            hl.FillColor = color
            hl.OutlineColor = color
            table.insert(data.highlights, hl)
        end
    end

    -- Billboard для имени
    local head = char:FindFirstChild("Head")
    if head then
        local bill = Instance.new("BillboardGui")
        bill.Size = UDim2.new(0, 200, 0, 50)
        bill.Adornee = head
        bill.StudsOffset = Vector3.new(0, 2.5, 0)
        bill.AlwaysOnTop = true
        bill.MaxDistance = 200

        local frame = Instance.new("Frame", bill)
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BackgroundTransparency = 0.4
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
        frame.BackgroundColor3 = getRoleColor(player)

        local label = Instance.new("TextLabel", frame)
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = player.Name
        label.Font = Enum.Font.GothamBold
        label.TextSize = 16
        label.TextColor3 = Color3.new(1,1,1)
        label.TextStrokeTransparency = 0.3
        label.TextStrokeColor3 = Color3.new(0,0,0)

        bill.Parent = gui
        data.billboard = bill
    end

    -- Пересоздание при смене персонажа
    local conn = player.CharacterAdded:Connect(function(newChar)
        if playerHighlights[player] then
            local old = playerHighlights[player]
            for _, h in ipairs(old.highlights) do h:Destroy() end
            if old.billboard then old.billboard:Destroy() end
            for _, c in ipairs(old.connections) do pcall(c.Disconnect, c) end
            playerHighlights[player] = nil
        end
        task.wait(0.5)
        if espPlayers then createPlayerESP(player) end
    end)
    table.insert(data.connections, conn)

    playerHighlights[player] = data
end

local function updateAllPlayerESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if espPlayers then
                if not playerHighlights[player] then
                    createPlayerESP(player)
                else
                    -- Обновляем цвета
                    local data = playerHighlights[player]
                    if data then
                        local color = getRoleColor(player)
                        for _, hl in ipairs(data.highlights) do
                            hl.FillColor = color
                            hl.OutlineColor = color
                        end
                        if data.billboard then
                            local frame = data.billboard:FindFirstChildOfClass("Frame")
                            if frame then frame.BackgroundColor3 = color end
                        end
                    end
                end
            else
                if playerHighlights[player] then
                    local data = playerHighlights[player]
                    for _, h in ipairs(data.highlights) do h:Destroy() end
                    if data.billboard then data.billboard:Destroy() end
                    for _, c in ipairs(data.connections) do pcall(c.Disconnect, c) end
                    playerHighlights[player] = nil
                end
            end
        end
    end
end

